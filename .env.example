# =============================================================================
#  SecondBite – Root environment template
#  Copy this to .env and fill in REAL values before running docker-compose.
#  NEVER commit the .env file.
# =============================================================================

NODE_ENV=production
PORT=5000

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Credentials for the MongoDB container. Change ALL of these before deploying.
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=replace_with_strong_password

# Connection string used by the backend container (do not change the template).
DATABASE_URL=mongodb://${MONGO_ROOT_USER}:${MONGO_ROOT_PASS}@mongo:27017/secondbite?authSource=admin

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Cloudinary (Image Uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Frontend ─────────────────────────────────────────────────────────────────
# Host port the nginx container listens on (default: 80)
FRONTEND_PORT=80

# ── Seed script (optional) ───────────────────────────────────────────────────
# Set to "true" only when you deliberately want to wipe and re-seed the DB.
# SEED_CONFIRM=true
